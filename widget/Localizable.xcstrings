    "widget.cafeteria.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows the cafeteria menu for the current meal time."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 시간에 맞는 학식 메뉴를 보여줍니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在の時間帯に合う学食メニューを表示します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示当前时段的食堂菜单。"
          }
        }
      }
    },
