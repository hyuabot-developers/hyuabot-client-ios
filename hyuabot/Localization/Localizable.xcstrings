      }
    },
    "shuttle.service_notice.halt.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Shuttle service will be suspended on %@." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "%@はシャトルバスを運休します。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "%@에는 셔틀버스가 운행하지 않습니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "%@校车暂停运行。" } }
      }
    },
    "shuttle.service_notice.holiday.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Shuttles will run on the weekend/holiday schedule on %@." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "%@は週末/祝日ダイヤで運行します。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "%@에는 주말/공휴일 시간표로 운행합니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "%@将按周末/节假日时刻表运行。" } }
      }
    },
    "shuttle.service_notice.period.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "From %@, shuttles will follow the %@ schedule." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "%@からシャトルバスの運行期間が%@に変わります。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "%@부터 셔틀버스 운행이 %@ 일정으로 변경됩니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "自%@起，校车运行期间将变更为%@。" } }
      }
    },
