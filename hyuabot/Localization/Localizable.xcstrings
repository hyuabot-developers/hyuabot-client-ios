    "shuttle.service_notice.generic.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Check shuttle service information for %@." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "%@のシャトルバス運行情報を確認してください。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "%@ 셔틀버스 운행 정보를 확인해 주세요." } },
