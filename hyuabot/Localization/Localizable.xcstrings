      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can check the shuttle bus stop location and first and last bus times on the shuttle bus arrival information screen by pressing the stop information button at the bottom of each stop screen."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ى…”ي‹€ë²„ىٹ¤ ى •ë¥کى‍¥ ىœ„ى¹ک ë°ڈ ى²«ى°¨ ë§‰ى°¨ ى‹œê°„ى‌€ ى •ë¥کى‍¥ë³„ ي™”ë©´ ي•کë‹¨ى‌ک ى •ë¥کى‍¥ ى •ë³´ ë²„يٹ¼ى‌„ ëˆŒëں¬ ى…”ي‹€ë²„ىٹ¤ ëڈ„ى°© ى •ë³´ ي™”ë©´ى—گى„œ ي™•ى‌¸ي•  ىˆک ى‍ˆىٹµë‹ˆë‹¤."
