    "coach.shuttle.busAlternative.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When shuttle bus departures are infrequent, such as during breaks or on weekends, alternative route arrival information is provided for your convenience."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "休暇や週末などシャトルバスの配車間隔が長い時に活用できるよう、代替路線の到着情報が提供されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "방학이나 주말처럼 셔틀버스 배차 간격이 넓을 때 활용할 수 있도록 대체 노선의 도착 정보가 제공됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "假期或周末等校车发车间隔较长时，为方便出行将提供替代路线的到站信息。"
          }
        }
      }
    },
