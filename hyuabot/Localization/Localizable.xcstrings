          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "올해는 다시보지 않기"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今年は表示しない"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本年不再显示"
          }
        }
      }
    },
